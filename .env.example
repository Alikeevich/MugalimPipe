# Supabase (required - for authentication and database)
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Storage Setup:
# 1. Run supabase_setup.sql in Supabase SQL Editor
# 2. Create storage bucket named 'reports' (private, 10MB limit)
# 3. Add storage policies for user access control

# Vercel Environment Variables
# Set these in your Vercel dashboard under Settings > Environment Variables

# Yandex SpeechKit API (optional - for speech recognition)
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# Google Gemini AI API (optional - for AI analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Note: Without these API keys, the application will use mock data for demonstrations
